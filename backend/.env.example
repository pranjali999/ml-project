FLASK_ENV=development
# Set to 1 only if you want Flask auto-reload (starts two processes).
FLASK_DEBUG=0
# API port (5000 is often taken by macOS AirPlay / Control Center)
PORT=8000
SECRET_KEY=change-me-in-production

# MongoDB — leave EMPTY unless MongoDB is actually running (avoids connection warnings)
# MONGODB_URI=mongodb://localhost:27017
MONGODB_URI=
MONGODB_DB=agrimind

# OpenWeather (optional)
OPENWEATHER_API_KEY=
OPENWEATHER_UNITS=metric

# Optional LLM for chatbot (falls back to rules if empty)
OPENAI_API_KEY=
